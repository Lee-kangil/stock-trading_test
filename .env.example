# KIS Open API 설정 예시
# 이 파일을 복사해 '.env' 로 저장한 뒤 본인 값으로 채우세요.
#   PowerShell:  copy .env.example .env
# ※ 키는 '.env'에만 입력하세요. 이 .env.example 파일은 깃에 올라가는 템플릿이라
#    실제 키를 넣으면 노출됩니다. (.env 만 .gitignore 로 보호됩니다.)

# 환경: paper(모의투자, 권장 시작값) 또는 real(실전)
KIS_ENV=paper

# KIS Developers에서 발급한 앱키/앱시크릿
# ※ 모의투자용과 실전용 키가 다릅니다. KIS_ENV에 맞는 키를 넣으세요.
KIS_APP_KEY=여기에_앱키
KIS_APP_SECRET=여기에_앱시크릿

# 계좌번호: 앞 8자리 / 뒤 2자리(종합계좌는 01)
KIS_ACCOUNT=12345678
KIS_PRODUCT=01

# 실제 주문 전송 스위치 (0=시뮬레이션만, 1=실제 전송)
# 처음엔 반드시 0으로 두고 충분히 테스트하세요.
KIS_LIVE=0
